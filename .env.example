# 复制为 .env 并填入（局后自动触发，全程零确认）

# --- Cursor Automation Webhook（云端兜底，可选）---
# 在 Automations 编辑器保存后，复制 Webhook URL 到下一行：
# CURSOR_AUTOMATION_WEBHOOK_URL=https://...
# CURSOR_AUTOMATION_WEBHOOK_SECRET=

# --- 本地零确认处理器（默认开启，局末自动拉起）---
# GUANDAN_LOCAL_PROCESSOR=0   # 设为 0 可关闭本地 detached 处理器
# GUANDAN_LOCAL_AGENT=0       # 设为 0 可跳过 SDK 本地 Agent（仍跑 smoke/build/标 done）
# CURSOR_API_KEY=             # 可选：有则本地处理器用 @cursor/sdk 改策略
# GUANDAN_AGENT_MODEL=composer-2.5

# --- 非交互 git push（推荐开启）---
# pending / done 后自动 commit + push 到 origin/main，无需手动 push
GUANDAN_AUTO_GIT_PUSH=1
